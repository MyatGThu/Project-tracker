# Local secrets for `wrangler dev`. Copy to `worker/.dev.vars` (gitignored) and
# fill in. In production these are set with `npx wrangler secret put <NAME>`.

# Auth0 (REQUIRED — sign-in is Auth0 only, no password fallback). Must match the
# AUTH0 block in config.js (same domain + audience). Without these the Worker
# returns 503 on every /api route.
AUTH0_DOMAIN   = "your-tenant.us.auth0.com"
AUTH0_AUDIENCE = "https://api.poker-tracker"
